{
  "name": "patchly",
  "version": "0.1.0",
  "description": "Select any UI area on localhost, describe the change, watch the code update.",
  "type": "module",
  "exports": {
    ".": "./agent/index.js",
    "./vite": "./vite-plugin/index.js"
  },
  "bin": {
    "patchly": "./agent/index.js"
  },
  "scripts": {
    "agent": "tsx agent/index.js",
    "dev": "tsx watch agent/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p extension/tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "build:ext": "node -e \"console.log('build:ext is wired up in Phase 5')\"",
    "test": "node --test agent/ast/__tests__/operations.test.js agent/ast/__tests__/drift.test.js agent/ast/__tests__/property.test.js"
  },
  "dependencies": {
    "@babel/generator": "^7.24.0",
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "diff": "^9.0.0",
    "prettier": "^3.8.4",
    "ts-morph": "^28.0.0",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/diff": "^7.0.2",
    "@types/node": "^25.9.3",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
