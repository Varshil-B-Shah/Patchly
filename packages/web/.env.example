# ─── Patchly Web (Phase B) ────────────────────────────────────────────────────
# Copy to .env.local and fill in. Never commit the filled file.

MONGODB_URI=                 # MongoDB Atlas free-tier connection string
AUTH_SECRET=                 # openssl rand -base64 32
AUTH_GITHUB_ID=              # GitHub OAuth app client id
AUTH_GITHUB_SECRET=          # GitHub OAuth app client secret
NEXT_PUBLIC_APP_URL=http://localhost:3000   # used to build review shareUrl

# UPLOADTHING_TOKEN=         # added in Step 2

# Setup checklist:
#  1. MongoDB Atlas: create a free cluster, add a DB user, allow your IP (or 0.0.0.0/0 for dev).
#  2. GitHub OAuth app (Settings → Developer settings → OAuth Apps):
#       Homepage URL:               http://localhost:3000
#       Authorization callback URL: http://localhost:3000/api/auth/callback/github
